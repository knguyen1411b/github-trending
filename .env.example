# MongoDB Connection String (Atlas or Local MongoDB)
MONGODB_URI="mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/github-trending?retryWrites=true&w=majority"

# Google Gemini API Key (Get free API Key at https://aistudio.google.com/)
GEMINI_API_KEY="your_gemini_api_key_here"

# Telegram Bot Token (Get Bot Token from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN="your_telegram_bot_token_here"

# Vercel Cron Secret (For protecting /api/cron/telegram endpoint via ?secret= or Bearer header)
CRON_SECRET="your_cron_secret_key_here"

# Application Base URL (Change to https://your-domain.vercel.app when deploying)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
